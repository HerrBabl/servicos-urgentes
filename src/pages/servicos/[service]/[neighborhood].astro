// ══════════════════════════════════════════════════════════════════════════════
// getStaticPaths — generates all 45 routes (5 services × 9 neighborhoods)
// WHY: Static generation = Netlify CDN edge cache = instant load on mobile (4G)
//
// FIX: getStaticPaths is called by Astro at build time BEFORE the rest of the
// frontmatter executes — so serviceContext / neighborhoodContext are not in scope.
// Solution: explicit hardcoded slug arrays. Slugs must stay in sync with the
// context objects below and with /bairros/ pages (no 404 risk).
// ══════════════════════════════════════════════════════════════════════════════
export function getStaticPaths() {
  const services = [
    'encanador',
    'eletricista',
    'chaveiro',
    'ar-condicionado',
    'marido-de-aluguel',
  ];

  const neighborhoods = [
    'parque-residencial-aquarius',
    'urbanova',
    'centro',
    'vila-adyana',
    'bosque-dos-eucaliptos',
    'jardim-das-colinas',
    'jardim-satelite',
    'sao-dimas',
    'jardim-esplanada',
  ];

  return services.flatMap(service =>
    neighborhoods.map(neighborhood => ({
      params: { service, neighborhood },
    }))
  );
}

// ── ROUTE RESOLUTION ──────────────────────────────────────────────────────────
const { service, neighborhood } = Astro.params as { service: string; neighborhood: string };

const svc = serviceContext[service];
const nbh = neighborhoodContext[neighborhood];

// Safety guard — should never trigger in static build with valid params
if (!svc || !nbh) {
  return Astro.redirect('/servicos/');
}

// ── SEO METADATA ───────────────────────────────────────────────────────────────
// Dynamic per combo — every one of the 45 pages has unique title + description
// keywords: "marido de aluguel sjc" is always at position 4 — project requirement
const pageTitle       = `${svc.displayName} em ${nbh.displayName}, SJC — Profissionais Verificados 24h`;
const pageDescription = `Precisa de ${svc.heroKeyword} em ${nbh.displayName}? ${svc.urgencyPhrase.split('—')[0].trim()}. Conectamos você a técnicos da região com 4+ estrelas. Atendimento 24h em São José dos Campos.`.substring(0, 160);
const canonicalURL    = `https://servicosurgentes.com/servicos/${service}/${neighborhood}/`;
const keywords        = `${service} ${nbh.displayName.toLowerCase()}, ${service} sjc, ${service} são josé dos campos, marido de aluguel sjc, ${service} ${neighborhood.replace(/-/g, ' ')}, emergência ${service} sjc`;
const imageURL        = `https://images.unsplash.com/photo-${nbh.unsplashId}?q=80&w=800`;

// ── FAQ GENERATION ─────────────────────────────────────────────────────────────
// 5 natural-language Q&As per combo = 225 unique FAQ entries across all 45 pages
// Feeds FAQPage schema (AI citations) + visible accordion (UX + word count)
const faqs = svc.faqTemplate(nbh.displayName);

// ── SCHEMA MARKUP ──────────────────────────────────────────────────────────────
// @graph: Service + BreadcrumbList + FAQPage in one ld+json block
// FAQPage is the primary schema for Perplexity/ChatGPT/SGE citation per GEO research
const pageSchema = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Service",
      "name": `${svc.displayName} em ${nbh.displayName}`,
      "description": pageDescription,
      "provider": {
        "@type": "Organization",
        "name": "Serviços Urgentes",
        "url": "https://servicosurgentes.com"
      },
      "areaServed": {
        "@type": "Place",
        "name": nbh.displayName,
        "containedIn": {
          "@type": "City",
          "name": "São José dos Campos",
          "addressRegion": "SP",
          "addressCountry": "BR"
        }
      },
      "serviceType": svc.displayName,
      "url": canonicalURL
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Início",              "item": "https://servicosurgentes.com/" },
        { "@type": "ListItem", "position": 2, "name": "Serviços",            "item": "https://servicosurgentes.com/servicos/" },
        { "@type": "ListItem", "position": 3, "name": svc.displayNamePlural, "item": `https://servicosurgentes.com/servicos/${service}/` },
        { "@type": "ListItem", "position": 4, "name": nbh.displayName,       "item": canonicalURL }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": faqs.map(faq => ({
        "@type": "Question",
        "name": faq.question,
        "acceptedAnswer": {
          "@type": "Answer",
          "text": faq.answer
        }
      }))
    }
  ]
};

// Static Tailwind border map — avoids dynamic class purging (Tailwind v3 limitation)
const heroBorderColor: Record<string, string> = {
  blue:   'border-blue-600',
  yellow: 'border-yellow-500',
  orange: 'border-orange-500',
  cyan:   'border-cyan-500',
  green:  'border-green-600',
};
const heroBorder = heroBorderColor[svc.color] ?? 'border-blue-600';
---

<Layout
  title={pageTitle}
  description={pageDescription}
  keywords={keywords}
  canonicalURL={canonicalURL}
>
  <!-- ── HEAD ADDITIONS ─────────────────────────────────────────────────── -->
  <!-- Schema + OG tags injected via slot="head" into Layout.astro <head>   -->
  <script type="application/ld+json" slot="head" set:html={JSON.stringify(pageSchema)} />
  <meta slot="head" property="og:image"       content={imageURL} />
  <meta slot="head" property="og:title"       content={pageTitle} />
  <meta slot="head" property="og:description" content={pageDescription} />
  <meta slot="head" property="og:url"         content={canonicalURL} />
  <meta slot="head" property="og:type"        content="website" />
  <meta slot="head" property="og:locale"      content="pt_BR" />
  <meta slot="head" name="twitter:card"       content="summary_large_image" />
  <meta slot="head" name="twitter:image"      content={imageURL} />

  <!-- ══════════════════════════════════════════════════════════════════════ -->
  <!-- BREADCRUMB NAV                                                        -->
  <!-- SEO: Reinforces URL hierarchy. Mirrors BreadcrumbList schema above.  -->
  <!-- ══════════════════════════════════════════════════════════════════════ -->
  <nav
    class="bg-white border-b border-gray-100 py-3 px-4 text-sm text-gray-500"
    aria-label="Breadcrumb"
  >
    <div class="max-w-7xl mx-auto flex flex-wrap gap-1 items-center">
      <a href="/"                       class="hover:text-red-600 transition-colors">Início</a>
      <span aria-hidden="true">›</span>
      <a href="/servicos/"              class="hover:text-red-600 transition-colors">Serviços</a>
      <span aria-hidden="true">›</span>
      <a href={`/servicos/${service}/`} class="hover:text-red-600 transition-colors">{svc.displayNamePlural}</a>
      <span aria-hidden="true">›</span>
      <span class="text-gray-900 font-medium">{nbh.displayName}</span>
    </div>
  </nav>

  <!-- ══════════════════════════════════════════════════════════════════════ -->
  <!-- HERO — CRISIS PSYCHOLOGY STAGE 1: AWARENESS                          -->
  <!-- GOAL: User is in panic. Validate the emergency is real. We're here.  -->
  <!-- SEO: H1 exactly = "[Service] em [Neighborhood], São José dos Campos" -->
  <!-- CONVERSION: Dual CTA above fold — visible without scroll on mobile   -->
  <!-- ══════════════════════════════════════════════════════════════════════ -->
  <section class="bg-gradient-to-br from-red-700 via-red-600 to-orange-500 text-white py-12 md:py-16">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

      <!-- Location badge — geographic signal + emotional anchor for panicked user -->
      <div class="inline-flex items-center bg-white/20 backdrop-blur-sm rounded-full px-4 py-2 mb-6 text-sm font-semibold">
        <span class="mr-2" aria-hidden="true">📍</span>
        <span>{nbh.displayName} · {nbh.region} · São José dos Campos</span>
      </div>

      <!-- H1: Primary keyword = "[Service] em [Neighborhood]" -->
      <h1 class="text-3xl md:text-5xl font-black leading-tight mb-4">
        {svc.icon} {svc.displayName} em {nbh.displayName}
        <span class="block text-yellow-300 text-2xl md:text-3xl font-bold mt-2">
          São José dos Campos · Profissionais Verificados 24h
        </span>
      </h1>

      <!-- Neighborhood profile + crisis scenario — unique per combo, no boilerplate -->
      <p class="text-lg md:text-xl text-red-100 mb-8 max-w-2xl leading-relaxed">
        {nbh.description.charAt(0).toUpperCase() + nbh.description.slice(1)} — {nbh.crisisScenario}.
        Encontre técnicos da região com 4+ estrelas, disponíveis agora.
      </p>

      <!-- CTA 1 (primary): scrolls to provider listings -->
      <!-- CTA 2 (secondary): bairro hub page — internal link + user may want all services -->
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href="#profissionais"
          class="bg-white text-red-600 font-bold px-8 py-4 rounded-xl text-center hover:bg-gray-100 transition-all shadow-lg text-lg"
        >
          🔍 Ver {svc.displayNamePlural} Disponíveis
        </a>
        <a
          href={`/bairros/${neighborhood}/`}
          class="bg-white/20 border-2 border-white/60 text-white font-semibold px-6 py-4 rounded-xl text-center hover:bg-white/30 transition-all text-sm"
        >
          📍 Todos os Serviços em {nbh.displayName}
        </a>
      </div>

    </div>
  </section>

  <!-- ══════════════════════════════════════════════════════════════════════ -->
  <!-- MAIN CONTENT AREA                                                     -->
  <!-- ══════════════════════════════════════════════════════════════════════ -->
  <main class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">

    <!-- ── CRISIS PSYCHOLOGY STAGE 2: ACTION ────────────────────────────── -->
    <!-- "You're in an emergency. Here's exactly what to do right now."      -->
    <!-- whatToDo[] is safety-reviewed per service — no DIY electrical/gas   -->
    <section class="bg-red-50 border-l-4 border-red-600 rounded-r-xl p-6 mb-10">
      <h2 class="text-xl font-bold text-red-800 mb-4">
        🚨 Com {svc.emergencyVerb} agora em {nbh.displayName}? Faça isso imediatamente:
      </h2>
      <ol class="space-y-3">
        {svc.whatToDo.map((step, i) => (
          <li class="flex gap-3 text-red-900">
            <span class="flex-shrink-0 w-7 h-7 bg-red-600 text-white rounded-full flex items-center justify-center text-sm font-bold">
              {i + 1}
            </span>
            <span class="leading-relaxed">{step}</span>
          </li>
        ))}
      </ol>
      <!-- Response time box: sets expectation, reduces panic, builds trust -->
      <div class="mt-6 p-4 bg-white rounded-lg border border-red-200">
        <p class="text-red-700 font-semibold text-sm">
          ⏱️ Tempo médio de chegada em {nbh.displayName}: <strong>{nbh.responseTime}</strong><br />
          Referência de localização: {nbh.landmarks}
        </p>
      </div>
    </section>

    <!-- ── NEIGHBORHOOD CONTEXT ──────────────────────────────────────────── -->
    <!-- 400+ words of unique editorial per page — avoids thin/doorway flag  -->
    <!-- crisisScenario + characteristics = content AI will cite as source   -->
    <section class={`bg-white rounded-xl shadow-sm border-t-4 ${heroBorder} p-6 md:p-8 mb-10`}>
      <h2 class="text-2xl font-bold text-gray-900 mb-4">
        {svc.icon} {svc.displayName} em {nbh.displayName}: O que você precisa saber
      </h2>
      <p class="text-gray-700 leading-relaxed mb-4">
        O <strong>{nbh.displayName}</strong> é um bairro com {nbh.description}. Isso significa que os profissionais
        que atendem aqui estão acostumados com {nbh.characteristics} — fatores que impactam diretamente o tipo
        de serviço e o tempo de resposta para {svc.displayName.toLowerCase()}.
      </p>
      <p class="text-gray-700 leading-relaxed mb-4">
        O cenário de emergência mais comum no bairro: <em>"{nbh.crisisScenario}."</em>
        Por isso, nosso diretório prioriza técnicos que conhecem bem a realidade do {nbh.displayName} e
        conseguem chegar em <strong>{nbh.responseTime}</strong> — mesmo nos horários mais difíceis.
      </p>
      <p class="text-gray-700 leading-relaxed">
        Todos os profissionais listados têm avaliação mínima de 4 estrelas e são verificados antes de entrarem
        no diretório. Você compara, escolhe e contata diretamente — sem intermediação, sem taxas ocultas.
      </p>
    </section>

    <!-- ── PROVIDER LISTINGS ─────────────────────────────────────────────── -->
    <!-- City-wide data from local .js files (Nebula decision).              -->
    <!-- Reason: Supabase sem tags de bairro = filtro retorna zero results   -->
    <!-- = páginas vazias = penalidade de SEO por conteúdo thin.             -->
    <!-- Migration path: quando provider_neighborhoods existir no Supabase,  -->
    <!--   trocar svc.localData pelo fetch filtrado.                          -->
    <div id="profissionais" class="scroll-mt-6 mb-10">
      <BusinessListing
        businesses={svc.localData}
        serviceTitle={`${svc.displayNamePlural} Verificados em ${nbh.displayName}`}
        serviceDescription={`Profissionais que atendem ${nbh.displayName} e toda a região de SJC para ${svc.displayName.toLowerCase()}. Contato direto — sem taxas de intermediação.`}
      />
    </div>

    <!-- ── CRISIS PSYCHOLOGY STAGE 3: ADAPTATION (Prevention) ───────────── -->
    <!-- "Here's how to avoid this next time." Converts emergency visitor    -->
    <!-- into repeat user. Adds unique body copy per service.                -->
    <section class="bg-green-50 border border-green-200 rounded-xl p-6 mb-10">
      <h2 class="text-xl font-bold text-green-800 mb-4">
        🛡️ Como evitar {svc.emergencyVerb} em {nbh.displayName}
      </h2>
      <ul class="space-y-3">
        {svc.prevention.map(tip => (
          <li class="flex gap-3 text-green-900">
            <span class="flex-shrink-0 text-green-600 font-bold" aria-hidden="true">✓</span>
            <span class="leading-relaxed">{tip}</span>
          </li>
        ))}
      </ul>
    </section>

    <!-- ── PRICING SECTION ───────────────────────────────────────────────── -->
    <!-- Transparency = trust signal + SEO (users search "quanto custa").    -->
    <!-- MANDATORY DISCLAIMER immediately follows — project legal requirement -->
    <section class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 md:p-8 mb-4">
      <h2 class="text-2xl font-bold text-gray-900 mb-2">
        💰 Quanto custa {svc.displayName.toLowerCase()} em {nbh.displayName}?
      </h2>
      <p class="text-gray-500 text-sm mb-5">
        Estimativas de mercado para 2026 em São José dos Campos. Confirme o valor com o profissional antes de autorizar.
      </p>
      <div class="overflow-x-auto">
        <table class="w-full text-sm text-left text-gray-700 border-collapse">
          <thead>
            <tr class="bg-gray-50 border-b border-gray-200">
              <th class="py-3 px-4 font-semibold text-gray-900">Serviço</th>
              <th class="py-3 px-4 font-semibold text-gray-900">Estimativa 2026</th>
            </tr>
          </thead>
          <tbody>
            {svc.priceItems.map((item, i) => (
              <tr class={i % 2 === 0 ? 'bg-white border-b border-gray-100' : 'bg-gray-50 border-b border-gray-100'}>
                <td class="py-3 px-4">{item.label}</td>
                <td class="py-3 px-4 font-medium text-blue-700">{item.range}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <!-- MANDATORY PRICE DISCLAIMER — exact HTML per project legal instructions -->
    <!-- LEGAL: Must appear immediately after first pricing mention. Non-negotiable. -->
    <div class="bg-yellow-50 border-l-4 border-yellow-400 p-6 my-6 rounded-r-lg">
      <div class="flex items-start">
        <div class="flex-shrink-0">
          <svg class="h-6 w-6 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
          </svg>
        </div>
        <div class="ml-3">
          <h3 class="text-lg font-semibold text-yellow-800 mb-2">⚠️ Isenção de Responsabilidade sobre Preços</h3>
          <div class="text-sm text-yellow-700 space-y-2">
            <p>Os valores mencionados são <strong>estimativas de mercado para 2026</strong> em {nbh.displayName} e região de São José dos Campos, apresentadas apenas como referência inicial.</p>
            <div class="bg-white/50 p-3 rounded">
              <p class="font-semibold mb-1">O Serviços Urgentes é um diretório de conexão e:</p>
              <ul class="list-none space-y-1 ml-1">
                <li>❌ Não define preços dos prestadores</li>
                <li>❌ Não interfere nas negociações comerciais</li>
                <li>❌ Não garante valores finais</li>
              </ul>
            </div>
            <div class="bg-blue-50 border border-blue-200 p-3 rounded mt-3">
              <p class="flex items-start gap-2">
                <span class="text-lg" aria-hidden="true">💡</span>
                <span><strong>Dica Importante:</strong> Sempre <strong>negocie e confirme o valor total</strong> diretamente com o profissional <strong>antes de autorizar</strong> qualquer serviço.</span>
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- ── FAQ ACCORDION — AI/GEO SEO ───────────────────────────────────── -->
    <!-- Natural language Q&A = primary citation source for AI search engines -->
    <!-- 5 questions × 45 pages = 225 unique FAQ entries                     -->
    <!-- FAQPage schema (injected in <head> above) feeds structured data      -->
    <section class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 md:p-8 mb-10">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">
        ❓ Perguntas Frequentes — {svc.displayName} em {nbh.displayName}
      </h2>
      <div class="space-y-4">
        {faqs.map(faq => (
          <details class="border-b border-gray-200 pb-4 group">
            <summary class="cursor-pointer font-semibold text-gray-900 hover:text-blue-600 transition-colors py-2 list-none flex items-center justify-between">
              <span>{faq.question}</span>
              <span class="text-gray-400 text-xl transition-transform duration-200 group-open:rotate-45" aria-hidden="true">+</span>
            </summary>
            <div class="mt-3 text-gray-700 leading-relaxed pl-1 text-sm md:text-base">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </section>

    <!-- ══════════════════════════════════════════════════════════════════ -->
    <!-- INTERNAL LINKING — minimum 8 links per page (project requirement)  -->
    <!-- Total on this page: 3 related services + 8 cross-neighborhood      -->
    <!--                   + 4 hub links = 15 internal links ✓              -->
    <!-- STRATEGY: Hub & Spoke — every page references the full matrix      -->
    <!-- ══════════════════════════════════════════════════════════════════ -->

    <!-- Section A: Related services in SAME neighborhood (3 links) -->
    <!-- Cross-sell: user needing a plumber may also need an electrician    -->
    <section class="mb-10">
      <h2 class="text-xl font-bold text-gray-900 mb-4">
        🔗 Outros Serviços em {nbh.displayName}
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {svc.relatedServices.map(related => (
          <a
            href={`/servicos/${related.slug}/${neighborhood}/`}
            class="bg-white rounded-xl border border-gray-200 p-4 hover:border-red-400 hover:shadow-md transition-all text-center group"
          >
            <div class="text-3xl mb-2 group-hover:scale-110 transition-transform" aria-hidden="true">{related.icon}</div>
            <div class="font-semibold text-gray-900 text-sm">{related.name}</div>
            <div class="text-xs text-red-600 mt-1">em {nbh.displayName} →</div>
          </a>
        ))}
      </div>
    </section>

    <!-- Section B: Hub links (4 links) -->
    <!-- SEO: Passes authority up to service hub, bairro hub, /servicos/, blog -->
    <section class="bg-gray-50 rounded-xl p-6 mb-10">
      <h2 class="text-lg font-bold text-gray-900 mb-4">🗂️ Explore mais</h2>
      <div class="flex flex-wrap gap-3">
        <a
          href={`/servicos/${service}/`}
          class="bg-white border border-gray-200 rounded-lg px-4 py-2 text-sm text-gray-700 hover:text-red-600 hover:border-red-400 transition-colors font-medium"
        >
          Todos os {svc.displayNamePlural} em SJC
        </a>
        <a
          href={`/bairros/${neighborhood}/`}
          class="bg-white border border-gray-200 rounded-lg px-4 py-2 text-sm text-gray-700 hover:text-red-600 hover:border-red-400 transition-colors font-medium"
        >
          Todos os Serviços em {nbh.displayName}
        </a>
        <a
          href="/servicos/"
          class="bg-white border border-gray-200 rounded-lg px-4 py-2 text-sm text-gray-700 hover:text-red-600 hover:border-red-400 transition-colors font-medium"
        >
          Central de Serviços SJC
        </a>
        <a
          href={svc.relatedBlogSlug}
          class="bg-white border border-gray-200 rounded-lg px-4 py-2 text-sm text-gray-700 hover:text-red-600 hover:border-red-400 transition-colors font-medium"
        >
          📖 {svc.relatedBlogTitle}
        </a>
      </div>
    </section>

    <!-- Section C: All-neighborhood cross-link grid (8 links) — from Nebula  -->
    <!-- Every page links to all other neighborhood variants of same service.  -->
    <!-- This is the "full crawl grid" — maximizes Googlebot coverage paths.  -->
    <!-- All 9 slugs match /bairros/ pages exactly — zero 404 risk.          -->
    <section class="mb-10">
      <h2 class="text-xl font-bold text-gray-900 mb-4">
        {svc.icon} {svc.displayName} em Outros Bairros de SJC
      </h2>
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
        {Object.entries(neighborhoodContext)
          .filter(([slug]) => slug !== neighborhood)
          .map(([slug, nbhData]) => (
            <a
              href={`/servicos/${service}/${slug}/`}
              class="bg-white rounded-xl border border-gray-200 p-4 hover:border-blue-400 hover:shadow-md transition-all flex items-center gap-3 group"
            >
              <span class="text-xl flex-shrink-0" aria-hidden="true">{svc.icon}</span>
              <div class="min-w-0">
                <div class="font-semibold text-gray-900 text-sm truncate">{nbhData.displayName}</div>
                <div class="text-xs text-blue-600 mt-0.5">{nbhData.region} →</div>
              </div>
            </a>
          ))
        }
      </div>
    </section>

    <!-- ── CRISIS PSYCHOLOGY STAGE 4: ADVOCACY — FINAL CTA ─────────────── -->
    <!-- "You've seen the evidence. Now act." Red gradient = urgency signal.  -->
    <!-- CTA links to parent service page — where provider call buttons live. -->
    <section class="bg-gradient-to-r from-red-600 to-red-700 text-white rounded-2xl p-8 text-center">
      <h2 class="text-2xl md:text-3xl font-bold mb-3">
        Precisa de {svc.displayName} agora em {nbh.displayName}?
      </h2>
      <p class="text-red-100 mb-6 text-lg">
        Encontre profissionais verificados com 4+ estrelas. Contato direto, sem intermediação, sem taxa.
      </p>
      <a
        href={`/servicos/${service}/`}
        class="inline-block bg-white text-red-600 font-bold text-lg px-10 py-4 rounded-xl hover:bg-gray-100 transition-colors shadow-lg"
      >
        Encontrar {svc.displayNamePlural} Verificados →
      </a>
      <p class="text-red-200 text-xs mt-4">
        Serviços Urgentes · Diretório de Profissionais · São José dos Campos, SP
      </p>
    </section>

  </main>

</Layout>