---
import Layout from '../../layouts/Layout.astro';
import BusinessListing from '../../components/BusinessListing.astro';
import { chaveiros } from '../../data/chaveiros.js';

// SEO Constants - Directory Model
const title = "Chaveiro em SJC — Abertura de Porta e Fechadura 24h";
const description = "Chaveiro 24h em São José dos Campos. Abertura residencial, chave quebrada e automotivo. Profissionais verificados no Centro, Aquarius, Urbanova e Vila Adyana.";
const keywords = "chaveiro sjc, chaveiro 24 horas são josé dos campos, abertura de porta sjc, marido de aluguel sjc, troca de fechadura, chaveiro automotivo centro sjc";
---

<Layout 
  title={title} 
  description={description}
  keywords={keywords}
>
 <!-- SEO H1: serviceTitle inside BusinessListing renders as H2; this provides the page H1 for crawlers -->
  <h1 class="sr-only">Chaveiros 24h em São José dos Campos</h1>

  <!-- DIRECTORY SCHEMA - COMPLIANT -->
  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": "https://servicosurgentes.com",
    "name": "Serviços Urgentes SJC",
    "description": "Diretório de profissionais verificados para serviços de emergência em São José dos Campos",
    "publisher": {
      "@type": "Organization",
      "name": "Serviços Urgentes",
      "url": "https://servicosurgentes.com"
    },
    "about": {
      "@type": "Service",
      "serviceType": "Locksmith",
      "name": "Serviços de Chaveiro 24h SJC",
      "description": "Diretório de chaveiros de emergência em São José dos Campos. Abertura de portas, fechaduras, cópias e chaveiro automotivo.",
      "areaServed": [
        { "@type": "City", "name": "São José dos Campos" },
        { "@type": "AdministrativeArea", "name": "Parque Residencial Aquarius" },
        { "@type": "AdministrativeArea", "name": "Bosque dos Eucaliptos" },
        { "@type": "AdministrativeArea", "name": "Centro" },
        { "@type": "AdministrativeArea", "name": "Jardim das Colinas" },
        { "@type": "AdministrativeArea", "name": "Jardim Esplanada" },
        { "@type": "AdministrativeArea", "name": "Jardim Satélite" },
        { "@type": "AdministrativeArea", "name": "São Dimas" },
        { "@type": "AdministrativeArea", "name": "Urbanova" },
        { "@type": "AdministrativeArea", "name": "Vila Adyana" }
      ],
      "availableChannel": {
        "@type": "ServiceChannel",
        "serviceUrl": "https://servicosurgentes.com/servicos/chaveiro/",
        "availableLanguage": "pt-BR"
      },
      "category": "Emergency Locksmith Services"
    }
  }
  </script>

  <script type="application/ld+json" slot="head">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Quanto custa abrir uma porta em São José dos Campos?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Para aberturas residenciais durante o dia, os valores em SJC ficam entre R$ 80 e R$ 150. Em plantão noturno, fins de semana e feriados, a faixa sobe para R$ 150 a R$ 250. O tipo de fechadura também influencia o valor. Sempre solicite orçamento completo incluindo taxa de deslocamento antes de confirmar."
      }
    },
    {
      "@type": "Question",
      "name": "Tem chaveiro 24h que atende Aquarius, Urbanova e Vila Adyana?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sim. Os profissionais listados no diretório Serviços Urgentes atendem toda São José dos Campos, incluindo Parque Residencial Aquarius, Urbanova e Vila Adyana. O tempo médio de chegada para esses bairros é de 25 a 40 minutos."
      }
    },
    {
      "@type": "Question",
      "name": "O chaveiro cobra taxa de deslocamento em SJC?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Muitos profissionais cobram taxa de visita ou deslocamento, especialmente em bairros mais afastados ou horário noturno. Essa taxa geralmente fica entre R$ 30 e R$ 80. Pergunte antes: 'o valor inclui o deslocamento?'"
      }
    },
    {
      "@type": "Question",
      "name": "Chaveiro pode abrir carro sem a chave original em SJC?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sim, chaveiros automotivos especializados abrem veículos sem a chave original sem danos. Para chaves codificadas com chip ou controle remoto, é necessário equipamento de programação específico, disponível em profissionais como Chaveiro do Alemão e Chaveiro Keytech em São José dos Campos."
      }
    },
    {
      "@type": "Question",
      "name": "Como funciona o diretório de chaveiros do Serviços Urgentes?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "O Serviços Urgentes é um diretório de conexão. Listamos profissionais com avaliações verificadas em plataformas públicas (4+ estrelas), endereço físico confirmado e contato direto. Você negocia diretamente com o profissional — não intermediamos pagamentos nem cobramos comissão."
      }
    }
  ]
}
</script>

  <BusinessListing 
    businesses={chaveiros}
    serviceTitle="Chaveiros Verificados em SJC"
    serviceDescription="Profissionais 24h para aberturas residenciais e automotivas em São José dos Campos."
  />

 <section class="py-12 bg-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

    <div id="inicio"></div>

    <h2 class="text-3xl font-bold text-gray-900 mb-6">
      Chaveiros 24h em São José dos Campos
    </h2>

    <div class="prose prose-lg max-w-none text-gray-700">

      <p class="text-xl text-gray-800 leading-relaxed mb-6">
        Porta travada. Chave quebrada dentro da fechadura. Chave esquecida dentro do carro. Quando isso acontece, cada minuto conta — especialmente à noite, na chuva, ou com crianças esperando do lado de fora. Os profissionais listados neste diretório atendem toda São José dos Campos, 24 horas por dia, incluindo fins de semana e feriados.
      </p>

      <h3 class="text-2xl font-semibold text-gray-900 mt-8 mb-4">
        ⏱️ Tempo de Chegada por Bairro (Referência 2026)
      </h3>
      <p>
        O tempo médio de atendimento varia conforme a localização e o horário. Como referência geral para São José dos Campos:
      </p>
      <ul class="list-disc pl-5 space-y-2 mb-6">
        <li><strong>Centro, Vila Adyana, São Dimas:</strong> 15–25 minutos</li>
        <li><strong>Jardim Satélite, Jardim Esplanada, Jardim das Colinas:</strong> 20–35 minutos</li>
        <li><strong>Aquarius, Bosque dos Eucaliptos, Urbanova:</strong> 25–40 minutos</li>
      </ul>
      <p class="text-sm text-gray-500 italic mb-6">
        Tempos são estimativas. Confirme disponibilidade e previsão de chegada diretamente com o profissional ao ligar.
      </p>

      [⬆️ Voltar ao topo](#inicio)

      <h3 class="text-2xl font-semibold text-gray-900 mt-8 mb-4">
        💰 Quanto Custa um Chaveiro em SJC? (Estimativas 2026)
      </h3>
      <p>
        Os preços variam conforme o horário (comercial vs. plantão noturno) e a complexidade da fechadura:
      </p>
      <ul class="list-disc pl-5 space-y-2 mb-6">
        <li><strong>Abertura de porta simples (dia):</strong> R$ 80–R$ 150</li>
        <li><strong>Abertura de porta (plantão/noite):</strong> R$ 150–R$ 250</li>
        <li><strong>Troca de segredo/cilindro:</strong> R$ 100–R$ 200 + custo da peça</li>
        <li><strong>Abertura de carro nacional:</strong> R$ 120–R$ 200</li>
        <li><strong>Chave codificada automotiva:</strong> R$ 200–R$ 500 conforme modelo</li>
      </ul>

      <!-- PRICE DISCLAIMER - DO NOT MODIFY -->
      <div class="bg-yellow-50 border-l-4 border-yellow-400 p-6 my-8 rounded-r-lg">
        <div class="flex items-start">
          <div class="flex-shrink-0">
            <svg class="h-6 w-6 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
            </svg>
          </div>
          <div class="ml-3">
            <h3 class="text-lg font-semibold text-yellow-800 mb-2">⚠️ Isenção de Responsabilidade sobre Preços</h3>
            <div class="text-sm text-yellow-700 space-y-2">
              <p>Os valores mencionados são <strong>estimativas de mercado para 2026</strong> na região de São José dos Campos, apresentadas apenas como referência inicial.</p>
              <div class="bg-white/50 p-3 rounded">
                <p class="font-semibold mb-1">O Serviços Urgentes é um diretório de conexão e:</p>
                <ul class="list-none space-y-1 ml-1">
                  <li>❌ Não define preços dos prestadores</li>
                  <li>❌ Não interfere nas negociações comerciais</li>
                  <li>❌ Não garante valores finais</li>
                </ul>
              </div>
              <div class="bg-blue-50 border border-blue-200 p-3 rounded mt-3">
                <p class="flex items-start gap-2">
                  <span class="text-lg">💡</span>
                  <span><strong>Dica Importante:</strong> Sempre <strong>negocie e confirme o valor total</strong> diretamente com o profissional <strong>antes de autorizar</strong> qualquer serviço.</span>
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>

      [⬆️ Voltar ao topo](#inicio)

      <h3 class="text-2xl font-semibold text-gray-900 mt-8 mb-4">
        ✅ 5 Perguntas Para Fazer Antes de Contratar um Chaveiro
      </h3>
      <p>
        Um profissional sério responde a estas perguntas com clareza, antes de sair para o atendimento:
      </p>
      <ol class="list-decimal pl-5 space-y-4 mb-6">
        <li>
          <strong>"Qual o valor total do serviço, incluindo deslocamento?"</strong><br/>
          <span class="text-gray-600">Profissionais transparentes informam uma faixa de preço por telefone. Desconfie de quem recusa dar qualquer estimativa antes de chegar.</span>
        </li>
        <li>
          <strong>"Vocês emitem recibo ou nota fiscal?"</strong><br/>
          <span class="text-gray-600">Chaveiros estabelecidos documentam o serviço. Isso protege você em caso de garantia ou problema posterior com a fechadura.</span>
        </li>
        <li>
          <strong>"Qual o tempo estimado de chegada?"</strong><br/>
          <span class="text-gray-600">Um número realista (ex: "40 minutos") é melhor sinal do que uma promessa vaga de "em breve". Confirme o bairro de atendimento.</span>
        </li>
        <li>
          <strong>"Quais formas de pagamento aceitam?"</strong><br/>
          <span class="text-gray-600">Pix, cartão de débito e crédito são padrão no mercado. Profissionais que aceitam apenas dinheiro em espécie merecem atenção extra.</span>
        </li>
        <li>
          <strong>"Têm avaliações no Google Maps que eu possa consultar?"</strong><br/>
          <span class="text-gray-600">Profissionais com histórico real têm avaliações verificadas. Os chaveiros listados neste diretório possuem 4+ estrelas em plataformas públicas.</span>
        </li>
      </ol>

      [⬆️ Voltar ao topo](#inicio)

      <!-- FAQ SECTION - VISIBLE + SCHEMA -->
      <h3 class="text-2xl font-semibold text-gray-900 mt-8 mb-6">
        ❓ Perguntas Frequentes — Chaveiro em SJC
      </h3>

      <div class="space-y-6">
        <div class="bg-gray-50 rounded-lg p-6">
          <h4 class="font-bold text-gray-900 mb-2">Quanto custa abrir uma porta em São José dos Campos?</h4>
          <p class="text-gray-700">Para aberturas residenciais durante o dia (horário comercial), os valores praticados em SJC ficam entre R$ 80 e R$ 150. Em plantão noturno, fins de semana e feriados, os preços sobem para a faixa de R$ 150 a R$ 250. O tipo de fechadura (simples, tetra ou digital) também influencia o valor final. Sempre solicite o orçamento completo, incluindo taxa de deslocamento, antes de confirmar o atendimento.</p>
        </div>

        <div class="bg-gray-50 rounded-lg p-6">
          <h4 class="font-bold text-gray-900 mb-2">Tem chaveiro 24h que atende Aquarius, Urbanova e Vila Adyana?</h4>
          <p class="text-gray-700">Sim. Os profissionais listados neste diretório atendem toda São José dos Campos, incluindo Parque Residencial Aquarius (próximo à Av. Cassiano Ricardo), Urbanova (Av. Possidônio José de Freitas) e Vila Adyana. O tempo médio de chegada para esses bairros é de 25 a 40 minutos, podendo variar conforme trânsito e disponibilidade do profissional no momento do chamado.</p>
        </div>

        <div class="bg-gray-50 rounded-lg p-6">
          <h4 class="font-bold text-gray-900 mb-2">O chaveiro cobra taxa de deslocamento em SJC?</h4>
          <p class="text-gray-700">Muitos profissionais cobram uma taxa de visita ou deslocamento, especialmente para bairros mais afastados do centro ou em horário noturno. Essa taxa geralmente fica entre R$ 30 e R$ 80 e pode ou não ser embutida no valor total do serviço. Por isso é importante perguntar: "o valor inclui o deslocamento?" antes de confirmar o atendimento.</p>
        </div>

        <div class="bg-gray-50 rounded-lg p-6">
          <h4 class="font-bold text-gray-900 mb-2">Chaveiro pode abrir carro sem a chave original em SJC?</h4>
          <p class="text-gray-700">Sim, chaveiros automotivos especializados conseguem abrir veículos sem a chave original usando ferramentas profissionais, sem danos à lataria ou vidros. Para chaves codificadas (com chip ou controle remoto), é necessário equipamento específico de programação — serviço disponível em chaveiros como Chaveiro do Alemão e Chaveiro Keytech, ambos listados neste diretório com atendimento em São José dos Campos.</p>
        </div>

        <div class="bg-gray-50 rounded-lg p-6">
          <h4 class="font-bold text-gray-900 mb-2">Como funciona o diretório de chaveiros do Serviços Urgentes?</h4>
          <p class="text-gray-700">O Serviços Urgentes é um diretório de conexão — listamos profissionais da região com avaliações verificadas em plataformas públicas (Google Maps, 4+ estrelas), endereço físico confirmado e contato direto via telefone e WhatsApp. Você negocia diretamente com o profissional. Não intermediamos pagamentos nem cobramos comissão dos prestadores listados.</p>
        </div>
      </div>

    </div>
  </div>
</section>

