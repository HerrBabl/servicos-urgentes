---
import Layout from '../../layouts/Layout.astro';
import BusinessListing from '../../components/BusinessListing.astro';
import { eletricistas } from '../../data/eletricistas.js';

// SEO Constants - Directory Model
const title = "Eletricista 24h SJC: Emergência e Manutenção | Técnicos Verificados";
const description = "⚡ Precisando de Eletricista em SJC? Conectamos você a profissionais 24h para curto-circuito, chuveiros e falta de luz. Atendimento no Centro, Aquarius, Urbanova e região.";
const keywords = "eletricista sjc, eletricista 24h são josé dos campos, curto circuito sjc, marido de aluguel sjc, instalação chuveiro sjc, eletricista predial";
---

<Layout 
  title={title} 
  description={description}
  keywords={keywords}
>
  <!-- WEATHER-REACTIVE BANNER - DIRECTORY COMPLIANT -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-6">
    <div class="bg-blue-50 border-l-4 border-blue-500 p-4 rounded-r-md shadow-sm">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-blue-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
          </svg>
        </div>
        <div class="ml-3">
          <p class="text-sm text-blue-700">
            <strong>Chuveiro queimou com a chuva?</strong> 
            Veja nosso <a href="/blog/chuveiro-queimado-sjc-guia" class="underline font-bold hover:text-blue-900">guia de troca de resistência</a> ou <strong>encontre um profissional</strong> em <a href="/servicos/marido-de-aluguel/" class="underline font-bold hover:text-blue-900">Marido de Aluguel</a> ou na lista abaixo.
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- DIRECTORY SCHEMA - COMPLIANT -->
  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": "https://servicosurgentes.com",
    "name": "Serviços Urgentes SJC",
    "description": "Diretório de profissionais verificados para serviços de emergência em São José dos Campos",
    "publisher": {
      "@type": "Organization",
      "name": "Serviços Urgentes",
      "url": "https://servicosurgentes.com"
    },
    "about": {
      "@type": "Service",
      "serviceType": "Electrician",
      "name": "Serviços de Eletricista 24h SJC",
      "description": "Diretório de eletricistas de emergência em São José dos Campos. Atendimento para quedas de energia, curtos-circuitos e instalações.",
      "areaServed": [
        { "@type": "City", "name": "São José dos Campos" },
        { "@type": "AdministrativeArea", "name": "Parque Residencial Aquarius" },
        { "@type": "AdministrativeArea", "name": "Bosque dos Eucaliptos" },
        { "@type": "AdministrativeArea", "name": "Centro" },
        { "@type": "AdministrativeArea", "name": "Jardim das Colinas" },
        { "@type": "AdministrativeArea", "name": "Jardim Esplanada" },
        { "@type": "AdministrativeArea", "name": "Jardim Satélite" },
        { "@type": "AdministrativeArea", "name": "São Dimas" },
        { "@type": "AdministrativeArea", "name": "Urbanova" },
        { "@type": "AdministrativeArea", "name": "Vila Adyana" }
      ],
      "availableChannel": {
        "@type": "ServiceChannel",
        "serviceUrl": "https://servicosurgentes.com/servicos/eletricista/",
        "availableLanguage": "pt-BR"
      },
      "category": "Emergency Electrical Services"
    }
  }
  </script>

  <BusinessListing 
    businesses={eletricistas}
    serviceTitle="Eletricistas Verificados em SJC"
    serviceDescription="Profissionais qualificados em SJC prontos para resolver sua emergência elétrica."
  />

  <section class="py-12 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-6">
        Serviços de Eletricista de Emergência em São José dos Campos
      </h2>
      
      <div class="prose prose-lg max-w-none text-gray-700">
        <h3 class="text-2xl font-semibold text-gray-900 mt-8 mb-4">
          Quando Chamar um Eletricista de Emergência
        </h3>
        <p>
          Problemas elétricos podem representar risco sério de incêndio ou choque elétrico. Chame um eletricista de emergência imediatamente se você perceber <strong>cheiro de queimado</strong> vindo de tomadas, disjuntores desarmando frequentemente (caindo a chave), ou faíscas. Seja no Aquarius, Bosque dos Eucaliptos, Centro, Jardim das Colinas, Jardim Esplanada, Jardim Satélite, São Dimas, Urbanova ou Vila Adyana, nosso diretório conecta você a profissionais qualificados. A oscilação de energia comum em dias de chuva em SJC também pode queimar aparelhos se não verificada.
        </p>

        <h3 class="text-2xl font-semibold text-gray-900 mt-8 mb-4">
          Quanto Custa um Serviço de Eletricista em SJC (Estimativas 2026)
        </h3>
        <p>
          Os preços variam conforme a complexidade e urgência. Em horário comercial, uma visita técnica custa entre R$ 100 e R$ 200. Serviços comuns incluem:
        </p>
        <ul class="list-disc pl-5 space-y-2 mb-6">
            <li><strong>Troca de disjuntor:</strong> R$ 150 - R$ 300</li>
            <li><strong>Reparo de curto-circuito:</strong> R$ 200 - R$ 500</li>
            <li><strong>Instalação de chuveiro elétrico:</strong> R$ 180 - R$ 350</li>
            <li><strong>Adequação de rede (aumento de carga):</strong> R$ 400 - R$ 1.200</li>
        </ul>

        <!-- PRICE DISCLAIMER - MANDATORY LEGAL PROTECTION -->
        <div class="bg-yellow-50 border-l-4 border-yellow-400 p-6 my-8 rounded-r-lg">
          <div class="flex items-start">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
              </svg>
            </div>
            <div class="ml-3">
              <h3 class="text-lg font-semibold text-yellow-800 mb-2">⚠️ Isenção de Responsabilidade sobre Preços</h3>
              <div class="text-sm text-yellow-700 space-y-2">
                <p>Os valores mencionados são <strong>estimativas de mercado para 2026</strong> na região de São José dos Campos, apresentadas apenas como referência inicial.</p>
                <div class="bg-white/50 p-3 rounded">
                  <p class="font-semibold mb-1">O Serviços Urgentes é um diretório de conexão e:</p>
                  <ul class="list-none space-y-1 ml-1">
                    <li>❌ Não define preços dos prestadores</li>
                    <li>❌ Não interfere nas negociações comerciais</li>
                    <li>❌ Não garante valores finais</li>
                  </ul>
                </div>
                <div class="bg-blue-50 border border-blue-200 p-3 rounded mt-3">
                  <p class="flex items-start gap-2">
                    <span class="text-lg">💡</span>
                    <span><strong>Dica Importante:</strong> Sempre <strong>negocie e confirme o valor total</strong> diretamente com o profissional <strong>antes de autorizar</strong> qualquer serviço.</span>
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- ENHANCED SAFETY SECTION WITH DIRECTORY CONNECTION -->
        <h3 class="text-2xl font-semibold text-gray-900 mt-8 mb-4">
          🚨 Segurança Primeiro: Quando NÃO Tentar Resolver Sozinho
        </h3>
        <div class="bg-red-50 border-l-4 border-red-500 p-6 mb-6 rounded-r-lg">
          <p class="font-bold text-red-900 mb-3">NUNCA tente reparos elétricos se você perceber:</p>
          <ul class="list-disc pl-5 space-y-2 text-red-800">
            <li><strong>Cheiro de queimado</strong> vindo do quadro de luz ou tomadas</li>
            <li><strong>Faíscas ou estouros</strong> ao ligar disjuntores</li>
            <li><strong>Choque elétrico</strong> ao tocar em aparelhos ou interruptores</li>
            <li><strong>Disjuntor desarmando repetidamente</strong> (sinal de curto-circuito)</li>
          </ul>
          <p class="mt-4 font-semibold text-red-900">
            ⚠️ Desligue o disjuntor geral e chame um profissional IMEDIATAMENTE. Risco de incêndio ou morte por eletrocussão.
          </p>
        </div>
        
        <div class="bg-blue-50 border-l-4 border-blue-500 p-4 rounded-r-lg my-6">
          <p class="text-sm text-blue-800">
            <strong>✓ Profissionais Qualificados:</strong> Todos os eletricistas listados neste diretório possuem conhecimento em <strong>NR-10</strong> (norma de segurança em eletricidade) e são avaliados pela comunidade com média de 4+ estrelas.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CROSS-SERVICE INTERNAL LINKING - ALL 4 SERVICES -->
  <section class="py-12 bg-white border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-gray-900 text-center mb-8">
        Outros Serviços Urgentes em SJC
      </h2>
      
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <a href="/servicos/encanador/" class="bg-gray-50 rounded-lg p-6 hover:bg-blue-50 hover:shadow-md transition">
          <div class="text-3xl mb-3 text-center">🔧</div>
          <h3 class="font-bold text-gray-900 mb-2 text-center">Encanadores 24h</h3>
          <p class="text-sm text-gray-600 text-center">Vazamentos e entupimentos urgentes</p>
        </a>
        
        <a href="/servicos/chaveiro/" class="bg-gray-50 rounded-lg p-6 hover:bg-blue-50 hover:shadow-md transition">
          <div class="text-3xl mb-3 text-center">🔑</div>
          <h3 class="font-bold text-gray-900 mb-2 text-center">Chaveiros 24h</h3>
          <p class="text-sm text-gray-600 text-center">Trancado para fora, cópias de chaves</p>
        </a>
        
        <a href="/servicos/ar-condicionado/" class="bg-gray-50 rounded-lg p-6 hover:bg-blue-50 hover:shadow-md transition">
          <div class="text-3xl mb-3 text-center">❄️</div>
          <h3 class="font-bold text-gray-900 mb-2 text-center">Ar-Condicionado</h3>
          <p class="text-sm text-gray-600 text-center">Instalação, limpeza e manutenção</p>
        </a>
        
        <a href="/servicos/marido-de-aluguel/" class="bg-gray-50 rounded-lg p-6 hover:bg-blue-50 hover:shadow-md transition">
          <div class="text-3xl mb-3 text-center">🛠️</div>
          <h3 class="font-bold text-gray-900 mb-2 text-center">Marido de Aluguel</h3>
          <p class="text-sm text-gray-600 text-center">Reparos gerais e instalações</p>
        </a>
      </div>
    </div>
  </section>

<section class="py-16 bg-gray-50 border-t border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 text-center mb-4">
        ⚡ Eletricistas por Bairro em SJC
      </h2>
      <p class="text-gray-600 text-center mb-10 max-w-2xl mx-auto">
        Encontre eletricistas verificados no seu bairro para atendimento mais rápido.
      </p>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        <a href="/servicos/eletricista/centro/" class="group bg-white p-5 rounded-xl shadow-sm border border-gray-100 hover:shadow-md hover:border-yellow-500 transition-all text-center">
          <div class="text-3xl mb-2 group-hover:scale-110 transition-transform">🏢</div>
          <div class="font-bold text-gray-900 text-sm">Centro</div>
          <div class="text-xs text-yellow-600 font-medium mt-1">Ver Eletricistas →</div>
        </a>
        <a href="/servicos/eletricista/parque-residencial-aquarius/" class="group bg-white p-5 rounded-xl shadow-sm border border-gray-100 hover:shadow-md hover:border-yellow-500 transition-all text-center">
          <div class="text-3xl mb-2 group-hover:scale-110 transition-transform">🏙️</div>
          <div class="font-bold text-gray-900 text-sm">Aquarius</div>
          <div class="text-xs text-yellow-600 font-medium mt-1">Ver Eletricistas →</div>
        </a>
        <a href="/servicos/eletricista/urbanova/" class="group bg-white p-5 rounded-xl shadow-sm border border-gray-100 hover:shadow-md hover:border-yellow-500 transition-all text-center">
          <div class="text-3xl mb-2 group-hover:scale-110 transition-transform">🏡</div>
          <div class="font-bold text-gray-900 text-sm">Urbanova</div>
          <div class="text-xs text-yellow-600 font-medium mt-1">Ver Eletricistas →</div>
        </a>
        <a href="/servicos/eletricista/vila-adyana/" class="group bg-white p-5 rounded-xl shadow-sm border border-gray-100 hover:shadow-md hover:border-yellow-500 transition-all text-center">
          <div class="text-3xl mb-2 group-hover:scale-110 transition-transform">🌳</div>
          <div class="font-bold text-gray-900 text-sm">Vila Adyana</div>
          <div class="text-xs text-yellow-600 font-medium mt-1">Ver Eletricistas →</div>
        </a>
        <a href="/servicos/eletricista/bosque-dos-eucaliptos/" class="group bg-white p-5 rounded-xl shadow-sm border border-gray-100 hover:shadow-md hover:border-yellow-500 transition-all text-center">
          <div class="text-3xl mb-2 group-hover:scale-110 transition-transform">🌲</div>
          <div class="font-bold text-gray-900 text-sm">Bosque dos Eucaliptos</div>
          <div class="text-xs text-yellow-600 font-medium mt-1">Ver Eletricistas →</div>
        </a>
        <a href="/servicos/eletricista/jardim-das-colinas/" class="group bg-white p-5 rounded-xl shadow-sm border border-gray-100 hover:shadow-md hover:border-yellow-500 transition-all text-center">
          <div class="text-3xl mb-2 group-hover:scale-110 transition-transform">🏘️</div>
          <div class="font-bold text-gray-900 text-sm">Jardim das Colinas</div>
          <div class="text-xs text-yellow-600 font-medium mt-1">Ver Eletricistas →</div>
        </a>
        <a href="/servicos/eletricista/jardim-satelite/" class="group bg-white p-5 rounded-xl shadow-sm border border-gray-100 hover:shadow-md hover:border-yellow-500 transition-all text-center">
          <div class="text-3xl mb-2 group-hover:scale-110 transition-transform">🛖</div>
          <div class="font-bold text-gray-900 text-sm">Jardim Satélite</div>
          <div class="text-xs text-yellow-600 font-medium mt-1">Ver Eletricistas →</div>
        </a>
        <a href="/servicos/eletricista/sao-dimas/" class="group bg-white p-5 rounded-xl shadow-sm border border-gray-100 hover:shadow-md hover:border-yellow-500 transition-all text-center">
          <div class="text-3xl mb-2 group-hover:scale-110 transition-transform">⛪</div>
          <div class="font-bold text-gray-900 text-sm">São Dimas</div>
          <div class="text-xs text-yellow-600 font-medium mt-1">Ver Eletricistas →</div>
        </a>
        <a href="/servicos/eletricista/jardim-esplanada/" class="group bg-white p-5 rounded-xl shadow-sm border border-gray-100 hover:shadow-md hover:border-yellow-500 transition-all text-center">
          <div class="text-3xl mb-2 group-hover:scale-110 transition-transform">🏗️</div>
          <div class="font-bold text-gray-900 text-sm">Jardim Esplanada</div>
          <div class="text-xs text-yellow-600 font-medium mt-1">Ver Eletricistas →</div>
        </a>
      </div>
    </div>
  </section>
</Layout>
