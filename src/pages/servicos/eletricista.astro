---
import Layout from '../../layouts/Layout.astro';
import BusinessListing from '../../components/BusinessListing.astro';
import { eletricistas } from '../../data/eletricistas.js';

// SEO Constants - Directory Model
const title = "Eletricista Residencial em SJC — Curto, Chuveiro e Emergências 24h";
const description = "Eletricista em SJC agora — curto, chuveiro queimado ou sem luz? Técnicos verificados 24h no Aquarius, Urbanova e Centro. Contato direto, sem intermediação.";
const keywords = "eletricista sjc, eletricista 24h são josé dos campos, curto circuito sjc, marido de aluguel sjc, instalação chuveiro sjc, eletricista predial";
---

<Layout 
  title={title} 
  description={description}
  keywords={keywords}
>
<!-- SEO H1: serviceTitle inside BusinessListing renders as H2; this provides the page H1 for crawlers -->
  <h1 class="sr-only">Eletricistas 24h em São José dos Campos</h1>
  
  <!-- WEATHER-REACTIVE BANNER - DIRECTORY COMPLIANT -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-6">
    <div class="bg-blue-50 border-l-4 border-blue-500 p-4 rounded-r-md shadow-sm">
      <div class="flex">
        <div class="flex-shrink-0">
          <svg class="h-5 w-5 text-blue-400" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
          </svg>
        </div>
        <div class="ml-3">
          <p class="text-sm text-blue-700">
            <strong>Chuveiro queimou com a chuva?</strong> 
            Veja nosso <a href="/blog/chuveiro-queimado-sjc-guia/" class="underline font-bold hover:text-blue-900">guia de troca de resistência</a> ou <strong>encontre um profissional</strong> em <a href="/servicos/marido-de-aluguel/" class="underline font-bold hover:text-blue-900">Marido de Aluguel</a> ou na lista abaixo.
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- DIRECTORY SCHEMA - COMPLIANT -->
  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": "https://servicosurgentes.com",
    "name": "Serviços Urgentes SJC",
    "description": "Diretório de profissionais verificados para serviços de emergência em São José dos Campos",
    "publisher": {
      "@type": "Organization",
      "name": "Serviços Urgentes",
      "url": "https://servicosurgentes.com"
    },
    "about": {
      "@type": "Service",
      "serviceType": "Electrician",
      "name": "Serviços de Eletricista 24h SJC",
      "description": "Diretório de eletricistas de emergência em São José dos Campos. Atendimento para quedas de energia, curtos-circuitos e instalações.",
      "areaServed": [
        { "@type": "City", "name": "São José dos Campos" },
        { "@type": "AdministrativeArea", "name": "Parque Residencial Aquarius" },
        { "@type": "AdministrativeArea", "name": "Bosque dos Eucaliptos" },
        { "@type": "AdministrativeArea", "name": "Centro" },
        { "@type": "AdministrativeArea", "name": "Jardim das Colinas" },
        { "@type": "AdministrativeArea", "name": "Jardim Esplanada" },
        { "@type": "AdministrativeArea", "name": "Jardim Satélite" },
        { "@type": "AdministrativeArea", "name": "São Dimas" },
        { "@type": "AdministrativeArea", "name": "Urbanova" },
        { "@type": "AdministrativeArea", "name": "Vila Adyana" }
      ],
      "availableChannel": {
        "@type": "ServiceChannel",
        "serviceUrl": "https://servicosurgentes.com/servicos/eletricista/",
        "availableLanguage": "pt-BR"
      },
      "category": "Emergency Electrical Services"
    }
  }
  </script>

  <script type="application/ld+json" slot="head">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "O disjuntor fica caindo — precisa de eletricista urgente?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Se o disjuntor cai repetidamente ou há cheiro de queimado, é sinal de curto-circuito ativo: chame um eletricista imediatamente e desligue o geral. Em SJC, o tempo médio de chegada para emergências é de 20 a 40 minutos dependendo do bairro."
      }
    },
    {
      "@type": "Question",
      "name": "Tem eletricista 24h que atende Aquarius, Urbanova e Bosque dos Eucaliptos?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sim. Os profissionais listados atendem toda SJC em regime 24h, incluindo Parque Residencial Aquarius, Urbanova e Bosque dos Eucaliptos. Tempo estimado de chegada: 25 a 40 minutos para esses bairros."
      }
    },
    {
      "@type": "Question",
      "name": "Quanto custa instalar um chuveiro elétrico em SJC?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Entre R$ 180 e R$ 350 com mão de obra. Se precisar puxar fiação nova do quadro, o valor pode subir para R$ 400–R$ 600. Solicite orçamento especificando se já existe ponto elétrico adequado."
      }
    },
    {
      "@type": "Question",
      "name": "Eletricista cobra mais caro à noite e no fim de semana?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sim. Plantão noturno e fins de semana geralmente têm acréscimo de 30% a 50% sobre o valor diurno. Confirme o valor total incluindo taxa de plantão antes de autorizar a visita."
      }
    },
    {
      "@type": "Question",
      "name": "Como funciona o diretório de eletricistas do Serviços Urgentes?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Diretório de conexão com eletricistas verificados (4+ estrelas no Google Maps), endereço físico confirmado e contato direto. Você negocia diretamente com o profissional — sem intermediação de pagamentos ou comissão."
      }
    }
  ]
}
</script>

  <BusinessListing 
    businesses={eletricistas}
    serviceTitle="Eletricistas Verificados em SJC"
    serviceDescription="Profissionais qualificados em SJC prontos para resolver sua emergência elétrica."
  />

  <section class="py-12 bg-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

    <div id="inicio"></div>

    <h2 class="text-3xl font-bold text-gray-900 mb-6">
      Eletricistas 24h em São José dos Campos
    </h2>

    <div class="prose prose-lg max-w-none text-gray-700">

      <p class="text-xl text-gray-800 leading-relaxed mb-6">
        Cheiro de queimado. Disjuntor que não para de cair. Chuveiro que deu um estalo e apagou. Em São José dos Campos, problemas elétricos acontecem mais nos dias de chuva — justamente quando você menos pode esperar. Os eletricistas listados aqui atendem toda SJC, 24 horas, incluindo fins de semana e feriados.
      </p>

      <div class="text-sm text-gray-500 border-l-4 border-blue-200 pl-4 my-4">
        <strong>Resumo rápido:</strong> Eletricista 24h atende curto-circuito, disjuntor caindo e falhas elétricas em SJC. O Serviços Urgentes é um diretório que conecta você a profissionais verificados, com atendimento a partir de R$ 100 e chegada a partir de 15 minutos no Centro.
      </div>

      <div class="bg-red-50 border-l-4 border-red-500 p-6 mb-8 rounded-r-lg">
        <p class="font-bold text-red-900 mb-3">🚨 Chame um profissional IMEDIATAMENTE se você perceber:</p>
        <ul class="list-disc pl-5 space-y-1 text-red-800">
          <li><strong>Cheiro de queimado</strong> vindo de tomadas ou do quadro de luz</li>
          <li><strong>Faíscas ou estalos</strong> ao ligar disjuntores ou aparelhos</li>
          <li><strong>Disjuntor desarmando repetidamente</strong> — sinal de curto-circuito ativo</li>
          <li><strong>Choque elétrico</strong> ao tocar interruptores ou torneiras</li>
        </ul>
        <p class="mt-4 font-semibold text-red-900">
          ⚠️ Desligue o disjuntor geral e saia da área. Não tente resolver sozinho — risco de incêndio e morte por eletrocussão.
        </p>
      </div>

      <h3 class="text-2xl font-semibold text-gray-900 mt-8 mb-4">
        ⏱️ Tempo de Chegada por Bairro (Referência 2026)
      </h3>
      <p>Tempo médio de atendimento para emergências elétricas em SJC:</p>
      <ul class="list-disc pl-5 space-y-2 mb-6">
        <li><strong>Centro, Vila Adyana, São Dimas:</strong> 15–25 minutos</li>
        <li><strong>Jardim Satélite, Jardim Esplanada, Jardim das Colinas:</strong> 20–35 minutos</li>
        <li><strong>Aquarius, Bosque dos Eucaliptos, Urbanova:</strong> 25–40 minutos</li>
      </ul>
      <p class="text-sm text-gray-500 italic mb-6">
        Tempos são estimativas. Confirme disponibilidade e previsão de chegada ao ligar.
      </p>

      [⬆️ Voltar ao topo](#inicio)

      <h3 class="text-2xl font-semibold text-gray-900 mt-8 mb-4">
        💰 Quanto Custa um Eletricista em SJC? (Estimativas 2026)
      </h3>
      <ul class="list-disc pl-5 space-y-2 mb-6">
        <li><strong>Visita técnica (horário comercial):</strong> R$ 100–R$ 200</li>
        <li><strong>Troca de disjuntor:</strong> R$ 150–R$ 300</li>
        <li><strong>Reparo de curto-circuito:</strong> R$ 200–R$ 500</li>
        <li><strong>Instalação de chuveiro elétrico:</strong> R$ 180–R$ 350</li>
        <li><strong>Aumento de carga / adequação de rede:</strong> R$ 400–R$ 1.200</li>
        <li><strong>Plantão noturno / emergência:</strong> acréscimo de 30–50% sobre o valor diurno</li>
      </ul>

      <!-- PRICE DISCLAIMER - DO NOT MODIFY -->
