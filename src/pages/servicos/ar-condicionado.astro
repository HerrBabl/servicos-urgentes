---
import Layout from '../../layouts/Layout.astro';
import BusinessListing from '../../components/BusinessListing.astro';
import { ar_condicionado } from '../../data/ar_condicionado.js';

// SEO Constants - Directory Model
const title = "Ar-Condicionado SJC: Instalação, Limpeza e Conserto 24h | Técnicos 4+ Estrelas";
const description = "❄️ Precisando de técnico de Ar-Condicionado em SJC? Conectamos você a profissionais para instalação, limpeza e conserto. Atendimento no Aquarius, Urbanova, Centro e região.";
const keywords = "ar condicionado sjc, limpeza de ar condicionado sjc, técnico ar condicionado são josé dos campos, marido de aluguel sjc, instalação split sjc, conserto ar condicionado 24h";
---

<Layout 
  title={title}
  description={description}
  keywords={keywords}
>
  <!-- DIRECTORY SCHEMA - COMPLIANT -->
  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": "https://servicosurgentes.com",
    "name": "Serviços Urgentes SJC",
    "description": "Diretório de profissionais verificados para serviços de emergência em São José dos Campos",
    "publisher": {
      "@type": "Organization",
      "name": "Serviços Urgentes",
      "url": "https://servicosurgentes.com"
    },
    "about": {
      "@type": "Service",
      "serviceType": "HVAC",
      "name": "Serviços de Ar Condicionado SJC",
      "description": "Diretório de técnicos de ar condicionado em São José dos Campos. Instalação, manutenção preventiva, limpeza, recarga de gás e reparos.",
      "areaServed": [
        { "@type": "City", "name": "São José dos Campos" },
        { "@type": "AdministrativeArea", "name": "Parque Residencial Aquarius" },
        { "@type": "AdministrativeArea", "name": "Bosque dos Eucaliptos" },
        { "@type": "AdministrativeArea", "name": "Centro" },
        { "@type": "AdministrativeArea", "name": "Jardim das Colinas" },
        { "@type": "AdministrativeArea", "name": "Jardim Esplanada" },
        { "@type": "AdministrativeArea", "name": "Jardim Satélite" },
        { "@type": "AdministrativeArea", "name": "São Dimas" },
        { "@type": "AdministrativeArea", "name": "Urbanova" },
        { "@type": "AdministrativeArea", "name": "Vila Adyana" }
      ],
      "availableChannel": {
        "@type": "ServiceChannel",
        "serviceUrl": "https://servicosurgentes.com/servicos/ar-condicionado/",
        "availableLanguage": "pt-BR"
      },
      "category": "HVAC and Air Conditioning Services"
    }
  }
  </script>

  <!-- PREVENTIVE MAINTENANCE ALERT - DIRECTORY COMPLIANT -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-6">
  <div class="bg-sky-50 border-l-4 border-sky-500 p-4 rounded-r-md shadow-sm">
    <div class="flex">
      <div class="flex-shrink-0">
        <span class="text-2xl">🛡️</span>
      </div>
      <div class="ml-3">
        <h3 class="text-sm font-bold text-sky-800 uppercase tracking-wide">
          Manutenção Preventiva
        </h3>
        <p class="text-sm text-sky-700 mt-1">
          Evite ficar na mão na próxima onda de calor. Agende sua limpeza química e recarga de gás <strong>antes</strong> da temperatura subir. <strong>Profissionais do nosso diretório</strong> reportam agenda disponível para esta semana.
        </p>
      </div>
    </div>
  </div>
</div>

  <BusinessListing 
    businesses={ar_condicionado}
    serviceTitle="Técnicos de Ar-Condicionado em SJC"
    serviceDescription="Especialistas em climatização e ar-condicionado em São José dos Campos, avaliados pela comunidade."
  />

  <section class="py-12 bg-blue-50 border-t border-blue-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900 mb-8 text-center">
        📖 Guias de Manutenção e Economia
      </h2>
      
      <div class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto">
        <a href="/blog/ar-condicionado-nao-gela-sjc/" class="bg-white rounded-lg shadow-md hover:shadow-xl transition-shadow p-6 group">
          <div class="flex items-start">
            <div class="text-3xl mr-4">❄️</div>
            <div class="flex-1">
              <h3 class="text-lg font-bold text-gray-900 mb-2 group-hover:text-red-600">
                Ar-Condicionado Não Gela? Protocolo de Emergência SJC
              </h3>
              <p class="text-gray-600 text-sm mb-3">
  Alta umidade e AC pingando? Saiba o que verificar antes de chamar o técnico, custos de reparo e como evitar mofo no sistema.
</p>
              <span class="text-red-600 font-semibold group-hover:underline text-sm">
                Ler artigo completo →
              </span>
            </div>
          </div>
        </a>

        <div class="bg-white rounded-lg shadow-md p-6 opacity-75">
          <div class="flex items-start">
            <div class="text-3xl mr-4">💰</div>
            <div class="flex-1">
              <h3 class="text-lg font-bold text-gray-900 mb-2">
                Manutenção Preventiva: Tabela de Preços 2026
              </h3>
              <p class="text-gray-600 text-sm mb-3">
                Saiba quanto custa manter seu ar limpo e evite gastos surpresa no verão.
              </p>
              <span class="text-gray-500 font-semibold text-sm">
                Em breve
              </span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 mb-6">
        Sobre Serviços de Ar-Condicionado em São José dos Campos
      </h2>
      
      <div class="prose prose-lg max-w-none text-gray-700">
        <h3 class="text-2xl font-semibold text-gray-900 mt-8 mb-4">
          Quando Chamar um Técnico Urgentemente
        </h3>
        <p>
          Em São José dos Campos, o calor pode ser intenso. Se você notar <strong>cheiro de queimado</strong>, vazamento de água na unidade interna (pinga-pinga), ou se o disjuntor desarmar ao ligar o aparelho, desligue tudo imediatamente e busque um profissional verificado.
        </p>

        <h3 class="text-2xl font-semibold text-gray-900 mt-8 mb-4">
          Serviços Disponíveis no Diretório
        </h3>
        <p>
          Conectamos você a especialistas em instalação de unidades split e inverter, manutenção preventiva (limpeza química), recarga de gás e reparos de placas. Seja no Aquarius, Bosque dos Eucaliptos, Centro, Jardim das Colinas, Jardim Esplanada, Jardim Satélite, São Dimas, Urbanova ou Vila Adyana, nossos profissionais listados atendem as principais marcas e possuem avaliação média de 4+ estrelas.
        </p>

        <h3 class="text-2xl font-semibold text-gray-900 mt-8 mb-4">
          Estimativa de Preços em SJC (Referência 2026)
        </h3>
        <p>
          Os valores variam pela complexidade. Uma higienização simples começa em média a partir de R$ 150-200. Instalações completas variam de R$ 400 a R$ 800 (sem materiais). Sempre solicite orçamento prévio através do contato direto com o técnico na listagem acima.
        </p>

        <!-- PRICE DISCLAIMER - MANDATORY LEGAL PROTECTION -->
        <div class="bg-yellow-50 border-l-4 border-yellow-400 p-6 my-8 rounded-r-lg">
          <div class="flex items-start">
            <div class="flex-shrink-0">
              <svg class="h-6 w-6 text-yellow-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>
            </div>
            <div class="ml-3">
              <h3 class="text-lg font-semibold text-yellow-800 mb-2">⚠️ Isenção de Responsabilidade sobre Preços</h3>
              <div class="text-sm text-yellow-700 space-y-2">
                <p>Os valores mencionados são <strong>estimativas de mercado para 2026</strong> na região de São José dos Campos, apresentadas apenas como referência inicial.</p>
                <div class="bg-white/50 p-3 rounded"><p class="font-semibold mb-1">O Serviços Urgentes é um diretório de conexão e:</p><ul class="list-none space-y-1 ml-1"><li>❌ Não define preços dos prestadores</li><li>❌ Não interfere nas negociações comerciais</li><li>❌ Não garante valores finais</li></ul></div>
                <div class="bg-blue-50 border border-blue-200 p-3 rounded mt-3"><p class="flex items-start gap-2"><span class="text-lg">💡</span><span><strong>Dica Importante:</strong> Sempre <strong>negocie e confirme o valor total</strong> diretamente com o profissional <strong>antes de autorizar</strong> qualquer serviço.</span></p></div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CROSS-SERVICE INTERNAL LINKING - ALL 4 SERVICES -->
  <section class="py-12 bg-white border-t border-gray-100">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-2xl font-bold text-gray-900 text-center mb-8">
        Outros Serviços Urgentes em SJC
      </h2>
      
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        <a href="/servicos/eletricista/" class="bg-gray-50 rounded-lg p-6 hover:bg-blue-50 hover:shadow-md transition">
          <div class="text-3xl mb-3">⚡</div>
          <h3 class="font-bold text-gray-900 mb-2">Eletricistas 24h</h3>
          <p class="text-sm text-gray-600">Disjuntor queimado, curto-circuito, oscilação de energia</p>
        </a>
        
        <a href="/servicos/encanador/" class="bg-gray-50 rounded-lg p-6 hover:bg-blue-50 hover:shadow-md transition">
          <div class="text-3xl mb-3">🔧</div>
          <h3 class="font-bold text-gray-900 mb-2">Encanadores 24h</h3>
          <p class="text-sm text-gray-600">Vazamentos, entupimentos, infiltrações urgentes</p>
        </a>
        
        <a href="/servicos/chaveiro/" class="bg-gray-50 rounded-lg p-6 hover:bg-blue-50 hover:shadow-md transition">
          <div class="text-3xl mb-3">🔑</div>
          <h3 class="font-bold text-gray-900 mb-2">Chaveiros 24h</h3>
          <p class="text-sm text-gray-600">Trancado para fora, cópias de chaves, fechaduras</p>
        </a>
        
        <a href="/servicos/marido-de-aluguel/" class="bg-gray-50 rounded-lg p-6 hover:bg-blue-50 hover:shadow-md transition">
          <div class="text-3xl mb-3">🛠️</div>
          <h3 class="font-bold text-gray-900 mb-2">Marido de Aluguel</h3>
          <p class="text-sm text-gray-600">Reparos gerais, instalações, manutenção residencial</p>
        </a>
      </div>
    </div>
  </section>

  <section class="py-16 bg-gray-50 border-t border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="text-3xl font-bold text-gray-900 text-center mb-4">
        ❄️ Técnicos de Ar-Condicionado por Bairro em SJC
      </h2>
      <p class="text-gray-600 text-center mb-10 max-w-2xl mx-auto">
        Encontre técnicos verificados no seu bairro para atendimento mais rápido.
      </p>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-4">
        <a href="/servicos/ar-condicionado/centro/" class="group bg-white p-5 rounded-xl shadow-sm border border-gray-100 hover:shadow-md hover:border-blue-400 transition-all text-center">
          <div class="text-3xl mb-2 group-hover:scale-110 transition-transform">🏢</div>
          <div class="font-bold text-gray-900 text-sm">Centro</div>
          <div class="text-xs text-blue-500 font-medium mt-1">Ver Técnicos →</div>
        </a>
        <a href="/servicos/ar-condicionado/parque-residencial-aquarius/" class="group bg-white p-5 rounded-xl shadow-sm border border-gray-100 hover:shadow-md hover:border-blue-400 transition-all text-center">
          <div class="text-3xl mb-2 group-hover:scale-110 transition-transform">🏙️</div>
          <div class="font-bold text-gray-900 text-sm">Aquarius</div>
          <div class="text-xs text-blue-500 font-medium mt-1">Ver Técnicos →</div>
        </a>
        <a href="/servicos/ar-condicionado/urbanova/" class="group bg-white p-5 rounded-xl shadow-sm border border-gray-100 hover:shadow-md hover:border-blue-400 transition-all text-center">
          <div class="text-3xl mb-2 group-hover:scale-110 transition-transform">🏡</div>
          <div class="font-bold text-gray-900 text-sm">Urbanova</div>
          <div class="text-xs text-blue-500 font-medium mt-1">Ver Técnicos →</div>
        </a>
        <a href="/servicos/ar-condicionado/vila-adyana/" class="group bg-white p-5 rounded-xl shadow-sm border border-gray-100 hover:shadow-md hover:border-blue-400 transition-all text-center">
          <div class="text-3xl mb-2 group-hover:scale-110 transition-transform">🌳</div>
          <div class="font-bold text-gray-900 text-sm">Vila Adyana</div>
          <div class="text-xs text-blue-500 font-medium mt-1">Ver Técnicos →</div>
        </a>
        <a href="/servicos/ar-condicionado/bosque-dos-eucaliptos/" class="group bg-white p-5 rounded-xl shadow-sm border border-gray-100 hover:shadow-md hover:border-blue-400 transition-all text-center">
          <div class="text-3xl mb-2 group-hover:scale-110 transition-transform">🌲</div>
          <div class="font-bold text-gray-900 text-sm">Bosque dos Eucaliptos</div>
          <div class="text-xs text-blue-500 font-medium mt-1">Ver Técnicos →</div>
        </a>
        <a href="/servicos/ar-condicionado/jardim-das-colinas/" class="group bg-white p-5 rounded-xl shadow-sm border border-gray-100 hover:shadow-md hover:border-blue-400 transition-all text-center">
          <div class="text-3xl mb-2 group-hover:scale-110 transition-transform">🏘️</div>
          <div class="font-bold text-gray-900 text-sm">Jardim das Colinas</div>
          <div class="text-xs text-blue-500 font-medium mt-1">Ver Técnicos →</div>
        </a>
        <a href="/servicos/ar-condicionado/jardim-satelite/" class="group bg-white p-5 rounded-xl shadow-sm border border-gray-100 hover:shadow-md hover:border-blue-400 transition-all text-center">
          <div class="text-3xl mb-2 group-hover:scale-110 transition-transform">🛖</div>
          <div class="font-bold text-gray-900 text-sm">Jardim Satélite</div>
          <div class="text-xs text-blue-500 font-medium mt-1">Ver Técnicos →</div>
        </a>
        <a href="/servicos/ar-condicionado/sao-dimas/" class="group bg-white p-5 rounded-xl shadow-sm border border-gray-100 hover:shadow-md hover:border-blue-400 transition-all text-center">
          <div class="text-3xl mb-2 group-hover:scale-110 transition-transform">⛪</div>
          <div class="font-bold text-gray-900 text-sm">São Dimas</div>
          <div class="text-xs text-blue-500 font-medium mt-1">Ver Técnicos →</div>
        </a>
        <a href="/servicos/ar-condicionado/jardim-esplanada/" class="group bg-white p-5 rounded-xl shadow-sm border border-gray-100 hover:shadow-md hover:border-blue-400 transition-all text-center">
          <div class="text-3xl mb-2 group-hover:scale-110 transition-transform">🏗️</div>
          <div class="font-bold text-gray-900 text-sm">Jardim Esplanada</div>
          <div class="text-xs text-blue-500 font-medium mt-1">Ver Técnicos →</div>
        </a>
      </div>
    </div>
  </section>
</Layout>
