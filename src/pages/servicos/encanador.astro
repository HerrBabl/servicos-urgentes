---
import Layout from '../../layouts/Layout.astro';
import BusinessListing from '../../components/BusinessListing.astro';
import { encanadores } from '../../data/encanadores.js';

// SEO Constants - Directory Model
const title = "Encanador em SJC — Caça-Vazamentos, Desentupimento e Emergências 24h";
const description = "Encanador 24h em São José dos Campos. Caça-vazamentos, desentupimento e infiltração. Técnicos verificados no Centro, Aquarius, Urbanova e Vila Adyana.";
const keywords = "encanador sjc, caça vazamentos sjc, desentupidora são josé dos campos, marido de aluguel sjc, encanador 24h centro sjc, conserto de tubulação";
---

<Layout 
  title={title} 
  description={description}
  keywords={keywords}
>
<!-- SEO H1: serviceTitle inside BusinessListing renders as H2; this provides the page H1 for crawlers -->
  <h1 class="sr-only">Encanadores 24h em São José dos Campos</h1>

  <!-- CRISIS ALERT: Rain/Storm Context -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-6">
    <div class="bg-blue-50 border-l-4 border-blue-600 p-4 rounded-r-md shadow-sm">
      <div class="flex">
        <div class="flex-shrink-0">
          <span class="text-2xl">🌧️</span>
        </div>
        <div class="ml-3">
          <h3 class="text-sm font-bold text-blue-800 uppercase tracking-wide">
            Alerta de Chuvas em SJC
          </h3>
          <p class="text-sm text-blue-700 mt-1">
            Alto índice de <strong>infiltrações e calhas entupidas</strong> detectado na região. Profissionais do nosso diretório reportam alta demanda para vazamentos de telhado e desentupimento pluvial hoje.
          </p>
          <p class="text-xs text-blue-600 mt-2 font-semibold">
            💡 Nosso diretório conecta você a encanadores disponíveis 24h em SJC
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- SCHEMA.ORG: WebSite/Directory Model (NOT Service Provider) -->
  <script type="application/ld+json" slot="head">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Serviços Urgentes - Diretório de Encanadores SJC",
    "description": "Diretório de encanadores de emergência 24h em São José dos Campos. Conectamos moradores a profissionais verificados para vazamentos, entupimentos e reparos urgentes.",
    "url": "https://servicosurgentes.com/servicos/encanador",
    "publisher": {
      "@type": "Organization",
      "name": "Serviços Urgentes",
      "url": "https://servicosurgentes.com"
    },
    "about": {
      "@type": "Thing",
      "name": "Diretório de Serviços de Encanamento",
      "description": "Plataforma de conexão entre moradores de São José dos Campos e profissionais de encanamento para emergências hidráulicas"
    },
    "spatialCoverage": [
      { "@type": "City", "name": "São José dos Campos" },
      { "@type": "AdministrativeArea", "name": "Parque Residencial Aquarius" },
      { "@type": "AdministrativeArea", "name": "Bosque dos Eucaliptos" },
      { "@type": "AdministrativeArea", "name": "Centro" },
      { "@type": "AdministrativeArea", "name": "Jardim das Colinas" },
      { "@type": "AdministrativeArea", "name": "Jardim Esplanada" },
      { "@type": "AdministrativeArea", "name": "Jardim Satélite" },
      { "@type": "AdministrativeArea", "name": "São Dimas" },
      { "@type": "AdministrativeArea", "name": "Urbanova" },
      { "@type": "AdministrativeArea", "name": "Vila Adyana" }
    ]
  }
  </script>

  <script type="application/ld+json" slot="head">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Cano estourou — o que fazer enquanto aguardo o encanador?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Feche o registro geral de água imediatamente, próximo ao hidrômetro. Se houver risco elétrico, desligue o disjuntor geral. Fotografe os danos. Não tente vedar canos pressurizados com fita. Em SJC, encanadores verificados chegam em 20 a 40 minutos dependendo do bairro."
      }
    },
    {
      "@type": "Question",
      "name": "Tem encanador 24h que atende Aquarius, Urbanova e Vila Adyana?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Sim. Os profissionais listados atendem toda SJC em regime 24h, incluindo Parque Residencial Aquarius (Av. Cassiano Ricardo), Urbanova (Av. Possidônio José de Freitas) e Vila Adyana. Tempo médio de chegada: 25 a 40 minutos."
      }
    },
    {
      "@type": "Question",
      "name": "Quanto custa desentupir vaso sanitário em SJC?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Entre R$ 150 e R$ 300 para entupimentos comuns. Casos com máquina rotativa: R$ 250–R$ 450. Confirme se o orçamento inclui taxa de deslocamento antes de autorizar."
      }
    },
    {
      "@type": "Question",
      "name": "O que é caça-vazamentos e quando preciso contratar?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Serviço de localização de vazamentos ocultos com geofone eletrônico, sem quebrar paredes. Indicado quando a conta de água aumentou inexplicavelmente, há manchas de umidade sem causa aparente, ou o hidrômetro gira com todos os registros fechados. Em SJC custa entre R$ 350 e R$ 600."
      }
    },
    {
      "@type": "Question",
      "name": "Como funciona o diretório de encanadores do Serviços Urgentes?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Diretório de conexão com encanadores verificados (4+ estrelas no Google Maps), endereço físico confirmado e contato direto. Você negocia diretamente com o profissional — sem intermediação de pagamentos ou comissão."
      }
    }
  ]
}
</script>

  <BusinessListing 
    businesses={encanadores}
    serviceTitle="Encanadores Verificados em SJC"
    serviceDescription="Conectamos você aos profissionais melhores avaliados para emergências hidráulicas 24h."
  />

  <section class="py-12 bg-white">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">

    <div id="inicio"></div>

    <h2 class="text-3xl font-bold text-gray-900 mb-6">
      Encanadores 24h em São José dos Campos
    </h2>

    <div class="prose prose-lg max-w-none text-gray-700">

      <p class="text-xl text-gray-800 leading-relaxed mb-6">
        Cano estourado. Vaso sanitário entupido que não para de transbordar. Mancha de umidade no teto que apareceu do nada. Em São José dos Campos, emergências hidráulicas acontecem a qualquer hora — e cada minuto de atraso aumenta o estrago. Os encanadores listados aqui atendem toda SJC, 24 horas, incluindo fins de semana e feriados.
      </p>

      <h3 class="text-2xl font-semibold text-gray-900 mt-8 mb-4">
        ⏱️ Tempo de Chegada por Bairro (Referência 2026)
      </h3>
      <p>Tempo médio de atendimento para emergências hidráulicas em SJC:</p>
      <ul class="list-disc pl-5 space-y-2 mb-6">
        <li><strong>Centro, Vila Adyana, São Dimas:</strong> 15–25 minutos</li>
        <li><strong>Jardim Satélite, Jardim Esplanada, Jardim das Colinas:</strong> 20–35 minutos</li>
        <li><strong>Aquarius, Bosque dos Eucaliptos, Urbanova:</strong> 25–40 minutos</li>
      </ul>
      <p class="text-sm text-gray-500 italic mb-6">
        Tempos são estimativas. Confirme disponibilidade e previsão de chegada ao ligar. Em emergências graves (cano estourado, água invadindo cômodo), feche o registro geral enquanto aguarda.
      </p>

      [⬆️ Voltar ao topo](#inicio)

      <h3 class="text-2xl font-semibold text-gray-900 mt-8 mb-4">
        💰 Quanto Custa um Encanador em SJC? (Estimativas 2026)
      </h3>
      <ul class="list-disc pl-5 space-y-2 mb-6">
        <li><strong>Visita técnica simples:</strong> R$ 80–R$ 150</li>
        <li><strong>Desentupimento (pia, vaso, ralo):</strong> R$ 150–R$ 300</li>
        <li><strong>Desentupimento com máquina rotativa:</strong> R$ 250–R$ 450</li>
        <li><strong>Caça-vazamentos com geofone eletrônico:</strong> R$ 350–R$ 600</li>
        <li><strong>Troca de reparo / válvula Hydra:</strong> R$ 120–R$ 200 + peça</li>
        <li><strong>Plantão noturno / emergência:</strong> acréscimo de 30–50% sobre o valor diurno</li>
      </ul>

