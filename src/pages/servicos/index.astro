---
import Layout from '../../layouts/Layout.astro';

const pageTitle = "Diretório de Profissionais de Emergência 24h em São José dos Campos";
const pageDescription = "O guia completo para encontrar encanador, eletricista, chaveiro, técnico de ar-condicionado e marido de aluguel 4+ estrelas em SJC e região.";
const canonicalURL = "https://servicosurgentes.com/servicos";

// Service categories
const services = [
  {
    name: "Encanador",
    icon: "💧",
    url: "/servicos/encanador/",
    description: "Vazamentos, entupimentos, reparos em aquecedores a gás e problemas em tubulações antigas."
  },
  {
    name: "Eletricista",
    icon: "⚡",
    url: "/servicos/eletricista/",
    description: "Quedas de energia, disjuntores desarmando, curto-circuitos e modernização de quadros de luz."
  },
  {
    name: "Chaveiro",
    icon: "🔑",
    url: "/servicos/chaveiro/",
    description: "Abertura de portas 24h, troca de segredos, fechaduras digitais e reparo de portões."
  },
  {
    name: "Ar-Condicionado",
    icon: "❄️",
    url: "/servicos/ar-condicionado/",
    description: "Manutenção de Multi-split, limpeza de filtros, recarga de gás e reparos urgentes no verão."
  },
  {
    name: "Marido de Aluguel",
    icon: "🛠️",
    url: "/servicos/marido-de-aluguel/",
    description: "Instalação de suportes de TV, montagem de móveis, furos em paredes e pequenos reparos domésticos."
  }
];

// Neighborhood pages - CRITICAL FOR SEO
const neighborhoods = [
  { name: "Parque Residencial Aquarius", url: "/bairros/parque-residencial-aquarius" },
  { name: "Urbanova", url: "/bairros/urbanova" },
  { name: 'Jardim Esplanada', url: '/bairros/jardim-esplanada' },
  { name: "Vila Adyana", url: "/bairros/vila-adyana" },
  { name: "Jardim das Colinas", url: "/bairros/jardim-das-colinas" },
  { name: "São Dimas", url: "/bairros/sao-dimas" },
  { name: "Centro", url: "/bairros/centro" },
  { name: "Bosque dos Eucaliptos", url: "/bairros/bosque-dos-eucaliptos" }
];
---

<Layout title={pageTitle} description={pageDescription} canonicalURL={canonicalURL}>
  <script type="application/ld+json" slot="head" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ItemList",
    "name": "Serviços de Emergência em São José dos Campos",
    "description": pageDescription,
    "itemListElement": services.map((service, index) => ({
      "@type": "ListItem",
      "position": index + 1,
      "item": {
        "@type": "Service",
        "name": service.name,
        "url": `https://servicosurgentes.com${service.url}`,
        "description": service.description
      }
    }))
  })} />

  <section class="bg-gradient-to-r from-blue-600 to-blue-800 text-white py-16">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <div class="inline-flex items-center bg-white/20 backdrop-blur-sm rounded-full px-6 py-3 mb-6">
          <span class="text-2xl mr-3">🚨</span>
          <span class="font-semibold">Emergências 24h</span>
        </div>
        <h1 class="text-4xl md:text-5xl font-bold mb-4">
          O Diretório Completo de Serviços de Emergência em SJC
        </h1>
        <p class="text-xl text-blue-100 max-w-3xl mx-auto">
          Seu guia essencial para encontrar profissionais de confiança, verificados e com avaliações acima de 4 estrelas, prontos para atender qualquer emergência na região de São José dos Campos.
        </p>
      </div>
    </div>
  </section>

  <section class="py-16 bg-gray-50" id="servicos">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Serviços Essenciais 24 Horas</h2>
        <p class="text-lg text-gray-600 max-w-2xl mx-auto">
          Encontre o especialista exato para sua necessidade, com foco em atendimento rápido e qualidade de serviço.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {services.map((service) => (
          <a 
            href={service.url}
            class="block p-6 bg-white rounded-lg hover:shadow-xl transition-shadow duration-300 border-2 border-blue-100 hover:border-blue-300"
          >
            <div class="text-4xl mb-3">{service.icon}</div>
            <h3 class="text-xl font-bold text-blue-900 mb-2">{service.name}</h3>
            <p class="text-gray-700">{service.description}</p>
            <div class="mt-4 text-blue-600 font-semibold flex items-center">
              Ver profissionais
              <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-gray-900 mb-4">Cobertura Local: Encontre por Bairro</h2>
        <p class="text-lg text-gray-600 max-w-3xl mx-auto">
          Nossos guias de bairro analisam as demandas específicas de cada região, garantindo que você encontre o profissional com o perfil certo para o seu tipo de imóvel (alto padrão, antigo, central, etc.).
        </p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
        {neighborhoods.map((neighborhood) => (
          <a 
            href={neighborhood.url}
            class="text-center p-4 bg-blue-50 border-2 border-blue-200 rounded-lg hover:bg-blue-100 hover:border-blue-400 transition-colors duration-200"
          >
            <p class="font-semibold text-blue-800">{neighborhood.name}</p>
          </a>
        ))}
      </div>
      
      <div class="mt-12 p-6 bg-gray-50 rounded-lg border border-gray-100">
        <h3 class="text-xl font-bold text-gray-900 mb-3">Como Funciona o Diretório</h3>
        <p class="text-gray-700">
          No Serviços Urgentes, você navega pelas categorias de serviço (Encanador, Eletricista, etc.) e utiliza o filtro por bairro para encontrar prestadores que atendem na sua região. Todos os profissionais listados são avaliados por clientes reais, ajudando você a tomar a decisão com segurança e agilidade.
        </p>
      </div>
    </div>
  </section>

  <section class="py-12 bg-red-600 text-white">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="text-2xl md:text-3xl font-bold mb-4">Precisa de Ajuda Urgente?</h2>
      <p class="text-lg text-red-100 mb-6">
        Escolha o serviço que você precisa e encontre profissionais verificados com 4+ estrelas prontos para atender.
      </p>
      <a 
        href="#servicos"
        class="inline-block bg-white text-red-600 px-8 py-3 rounded-lg font-semibold hover:bg-gray-100 transition-colors"
      >
        Encontrar Profissional Agora
      </a>
    </div>
  </section>
</Layout>