---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Serviços Urgentes - Emergência 24h em São José dos Campos">
   
<section class="relative overflow-hidden bg-gradient-to-br from-red-600 via-red-700 to-red-800 min-h-[80vh] flex items-center">
  <div class="absolute inset-0">
    <div class="absolute top-10 left-10 w-32 h-32 bg-white/60 rounded-full blur-xl animate-pulse"></div>
    <div class="absolute bottom-20 right-20 w-48 h-48 bg-orange-400/90 rounded-full blur-2xl animate-pulse delay-1000"></div>
    <div class="absolute top-1/2 left-1/4 w-20 h-20 bg-yellow-400/30 rounded-full blur-lg animate-pulse delay-500"></div>
  </div>
  
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
    <div class="text-center text-white">
      <div class="inline-flex items-center bg-white/20 backdrop-blur-sm rounded-full px-6 py-3 mb-8 border border-white/30">
        <span class="text-2xl mr-3">🚨</span>
        <span class="font-semibold text-lg">Emergência 24 Horas</span>
      </div>
      
      <h1 class="text-5xl md:text-7xl font-black mb-6 leading-tight">
        Precisa de Ajuda
        <span class="block text-yellow-300 drop-shadow-lg">URGENTE?</span>
      </h1>
      
      <p class="text-xl md:text-2xl mb-12 max-w-4xl mx-auto leading-relaxed text-red-100">
        Conectamos você aos <strong class="text-white">melhores profissionais</strong> de emergência 
        em São José dos Campos e Vale do Paraíba. Disponível 24h por dia, 7 dias por semana.
      </p>
      
      <div class="max-w-2xl mx-auto mb-12">
        <div class="relative">
          <div class="absolute inset-y-0 left-0 pl-6 flex items-center pointer-events-none">
            <span class="text-gray-400 text-xl">🔍</span>
          </div>
          <select 
            id="serviceSelector"
            class="w-full pl-16 pr-32 py-6 text-lg rounded-2xl border-0 bg-white/95 backdrop-blur-sm shadow-2xl text-gray-800 focus:ring-4 focus:ring-white/30 focus:outline-none appearance-none cursor-pointer"
          >
            <option value="">Selecione um serviço urgente...</option>
            <option value="/servicos/encanador/">🔧 Encanador 24h</option>
            <option value="/servicos/eletricista/">⚡ Eletricista 24h</option>
            <option value="/servicos/chaveiro/">🔑 Chaveiro 24h</option>
            <option value="/servicos/ar-condicionado/">❄️ Ar Condicionado 24h</option>
            <option value="/servicos/marido-de-aluguel/">🛠️ Marido de Aluguel</option>
          </select>
          <div class="absolute inset-y-0 right-0 pr-4 flex items-center">
            <button 
              id="goButton"
              class="bg-red-600 text-white px-8 py-4 rounded-xl font-bold hover:bg-red-700 transition-all duration-200 shadow-lg hover:shadow-xl disabled:opacity-50 disabled:cursor-not-allowed"
            >
              Ir
            </button>
          </div>
        </div>
      </div>

      <script>
        const selector = document.getElementById('serviceSelector');
        const goButton = document.getElementById('goButton');
        
        goButton?.addEventListener('click', () => {
          const value = (selector as HTMLSelectElement)?.value;
          if (value) {
            window.location.href = value;
          }
        });
        
        // Also allow pressing Enter or changing selection to navigate
        selector?.addEventListener('change', (e) => {
          const value = (e.target as HTMLSelectElement)?.value;
          if (value) {
            window.location.href = value;
          }
        });
      </script>
            
      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-4 max-w-6xl mx-auto mb-12">
        <a href="/servicos/encanador/" class="group bg-white/15 backdrop-blur-sm border border-white/30 rounded-xl p-6 hover:bg-white/25 transition-all duration-300 hover:scale-105">
          <div class="text-3xl mb-3">🔧</div>
          <div class="font-bold text-lg">Encanador</div>
        </a>
        <a href="/servicos/eletricista/" class="group bg-white/15 backdrop-blur-sm border border-white/30 rounded-xl p-6 hover:bg-white/25 transition-all duration-300 hover:scale-105">
          <div class="text-3xl mb-3">⚡</div>
          <div class="font-bold text-lg">Eletricista</div>
        </a>
        <a href="/servicos/chaveiro/" class="group bg-white/15 backdrop-blur-sm border border-white/30 rounded-xl p-6 hover:bg-white/25 transition-all duration-300 hover:scale-105">
          <div class="text-3xl mb-3">🔑</div>
          <div class="font-bold text-lg">Chaveiro</div>
        </a>
        <a href="/servicos/ar-condicionado/" class="group bg-white/15 backdrop-blur-sm border border-white/30 rounded-xl p-6 hover:bg-white/25 transition-all duration-300 hover:scale-105">
          <div class="text-3xl mb-3">❄️</div>
          <div class="font-bold text-lg">Ar Condicionado</div>
        </a>
        <a href="/servicos/marido-de-aluguel/" class="group bg-white/15 backdrop-blur-sm border border-white/30 rounded-xl p-6 hover:bg-white/25 transition-all duration-300 hover:scale-105">
          <div class="text-3xl mb-3">🛠️</div>
          <div class="font-bold text-lg leading-tight">Marido de Aluguel</div>
        </a>
      </div>
      
      </div>
  </div>
</section>

<section class="relative z-20 pb-12 mt-6 md:-mt-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-5 gap-4">
      
      <a href="/servicos/encanador/" class="bg-white rounded-lg shadow-lg p-6 border-b-4 border-blue-600 hover:-translate-y-1 transition-all flex items-center md:block text-left md:text-center group">
        <div class="text-3xl mr-4 md:mr-0 md:mb-2 group-hover:scale-110 transition-transform">💧</div>
        <div>
          <div class="font-bold text-gray-900 text-lg md:text-base">Vazamentos</div>
          <div class="text-xs text-blue-600 font-medium">Encanador 24h</div>
        </div>
      </a>

      <a href="/servicos/eletricista/" class="bg-white rounded-lg shadow-lg p-6 border-b-4 border-yellow-500 hover:-translate-y-1 transition-all flex items-center md:block text-left md:text-center group">
        <div class="text-3xl mr-4 md:mr-0 md:mb-2 group-hover:scale-110 transition-transform">⚡</div>
        <div>
          <div class="font-bold text-gray-900 text-lg md:text-base">Sem Luz?</div>
          <div class="text-xs text-yellow-600 font-medium">Eletricista</div>
        </div>
      </a>

      <a href="/servicos/chaveiro/" class="bg-white rounded-lg shadow-lg p-6 border-b-4 border-orange-500 hover:-translate-y-1 transition-all flex items-center md:block text-left md:text-center group">
        <div class="text-3xl mr-4 md:mr-0 md:mb-2 group-hover:scale-110 transition-transform">🔑</div>
        <div>
          <div class="font-bold text-gray-900 text-lg md:text-base">Trancado?</div>
          <div class="text-xs text-orange-600 font-medium">Chaveiro 24h</div>
        </div>
      </a>

      <a href="/servicos/ar-condicionado/" class="bg-white rounded-lg shadow-lg p-6 border-b-4 border-cyan-500 hover:-translate-y-1 transition-all flex items-center md:block text-left md:text-center group">
        <div class="text-3xl mr-4 md:mr-0 md:mb-2 group-hover:scale-110 transition-transform">❄️</div>
        <div>
          <div class="font-bold text-gray-900 text-lg md:text-base">Não Gela?</div>
          <div class="text-xs text-cyan-600 font-medium">Climatização</div>
        </div>
      </a>

      <a href="/servicos/marido-de-aluguel/" class="bg-white rounded-lg shadow-lg p-6 border-b-4 border-green-600 hover:-translate-y-1 transition-all flex items-center md:block text-left md:text-center group sm:col-span-2 md:col-span-1">
        <div class="text-3xl mr-4 md:mr-0 md:mb-2 group-hover:scale-110 transition-transform">🛠️</div>
        <div>
          <div class="font-bold text-gray-900 text-lg md:text-base">Reparos</div>
          <div class="text-xs text-green-600 font-medium">Pequenos Serviços</div>
        </div>
      </a>

    </div>
  </div>
</section>

